# Discord Bot Token (obligatoire)
BOT_TOKEN=your_discord_bot_token_here

# ID du serveur Discord (obligatoire)
GUILD_ID=your_discord_guild_id_here

# Twitch (optionnel - pour les alertes live)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_USERNAME=your_twitch_username
TWITCH_BROADCASTER_ID=

# YouTube (optionnel - pour les alertes vidéo)
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# Salon de bienvenue (optionnel)
WELCOME_CHANNEL_ID=

# Salon d'alerte live Twitch (ID du salon #live-alert)
LIVE_ALERT_CHANNEL_ID=

# PostgreSQL (Sliplane interne)
PG_HOST=postgres-3ixu.internal
PG_PORT=5432
PG_DB=mydb
PG_USER=postgres
PG_PASSWORD=CHANGE_ME
